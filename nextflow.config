// 1. Plugin and Cloud Configuration
plugins {
    id 'nf-amazon'
}

aws {
    region = 'us-east-1'
    client {
        // Critical for public buckets without IAM credentials
        anonymous = true 
    }
}

// 2. Global Parameters
params {
    input_s3 = 's3://tiffimage/tiffimage/*.tif' 
    outdir   = './results'
}

// 3. Process Specific Configurations
process {
    withName: 'CROP_AND_COMPRESS' {
        // Combined conda dependencies including matplotlib
        conda = 'conda-forge::tifffile conda-forge::numpy conda-forge::imagecodecs conda-forge::matplotlib'
    }
}

// 4. Engine Options
conda.enabled = true
